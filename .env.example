# Required: bot token from Discord Developer Portal
DISCORD_TOKEN=your-bot-token-here

# Optional: if set, slash commands sync only to this guild (instant updates).
# Leave unset for global sync (takes up to ~1 hour to propagate).
GUILD_ID=

# Optional: SQLite file path. On Railway with a Volume mounted at /app/data,
# set DB_PATH=/app/data/data.db so data survives redeploys.
DB_PATH=data.db

# Optional: name of the role allowed to run admin commands.
JUDGE_ROLE=Judge
